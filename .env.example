# OpenAI (required for risk scoring + simulation judge)
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# Slack (optional — dev mode auto-approves when empty)
SLACK_BOT_TOKEN=xoxb-YOUR_TOKEN
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Infrastructure
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite:///./guardian.db

# Behaviour
ALLOW_CRITICAL=false
APPROVAL_TIMEOUT=300
GUARDIAN_DEV_MODE=true
GUARDIAN_AUTO_APPROVE=false
SIMULATION_ENABLED=true
LOG_LEVEL=INFO
